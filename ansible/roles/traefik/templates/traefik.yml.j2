# Config statique Traefik — générée par Ansible

api:
  dashboard: true
  insecure: true  # Dashboard accessible en HTTP (port 8080)

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
  websecure:
    address: ":443"
  ssh-gitea:
    address: ":222"  # Port TCP pour SSH Gitea (utilisateurs git clone)

providers:
  file:
    directory: /etc/traefik/dynamic
    watch: true

certificatesResolvers:
  duckdns:
    acme:
      email: "pierrecgdev@gmail.com"
      storage: /etc/traefik/acme/acme.json
      dnsChallenge:
        provider: duckdns
        delayBeforeCheck: 30
        disablePropagationCheck: true

log:
  level: INFO
