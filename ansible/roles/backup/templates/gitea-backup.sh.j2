#!/bin/bash
set -e

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_FILE="gitea-${TIMESTAMP}.dump"
BUCKET="{{ backup_bucket_name }}"

PGPASSWORD="{{ db_password }}" pg_dump \
  -h "{{ rds_endpoint }}" \
  -U gitea \
  -d gitea \
  -F c \
  -f "/tmp/${BACKUP_FILE}"

aws s3 cp "/tmp/${BACKUP_FILE}" "s3://${BUCKET}/${BACKUP_FILE}"
rm -f "/tmp/${BACKUP_FILE}"

echo "[$(date)] Backup ${BACKUP_FILE} uploaded to s3://${BUCKET}"
